# Site Configuration
NUXT_PUBLIC_SITE_URL=https://yoursite.com
OWNER_NAME=Your Name
TWITTER_HANDLE=@yourhandle

# OpenStatus Widget (optional)
STATUS_SITE_SLUG=

# Umami Analytics (optional)
NUXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
NUXT_PUBLIC_UMAMI_WEBSITE_ID=

# Analytics (optional)
ANALYTICS_CLIENT_ID=
ANALYTICS_CLIENT_SECRET=

# Ably realtime visitor presence (optional, server-only)
ABLY_API_KEY=

# Minimal mode — hide icons in contact links, projects, blog cards, announcements, and footer (optional)
NUXT_PUBLIC_MINIMAL_MODE=false

# OG image generation (optional)
NUXT_OG_IMAGE_SECRET=

# NuxtHub (optional)
NUXT_HUB_USER_TOKEN=
NUXT_HUB_PROJECT_KEY=

# Nuxt Studio Configuration
STUDIO_ROUTE=/_studio
STUDIO_GITHUB_OWNER=
STUDIO_GITHUB_REPO=
STUDIO_GITHUB_BRANCH_NAME=main

# Nuxt Studio OAuth (for production deployment)
STUDIO_GITHUB_CLIENT_ID=
STUDIO_GITHUB_CLIENT_SECRET=

# Environment
NODE_ENV=
